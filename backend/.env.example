PROJECT_NAME=Homestay API
API_V1_STR=/api/v1
ENVIRONMENT=development

# Must be at least 32 characters in all environments.
SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256
PASSWORD_MIN_LENGTH=10

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=homestay

# JSON-style list for pydantic-settings.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["localhost","127.0.0.1"]

LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=600
PENDING_BOOKING_TTL_MINUTES=15
PAYMENT_TIMEOUT_MINUTES=15
PAYMENT_CALLBACK_MAX_AGE_SECONDS=900
PAYMENT_WEBHOOK_EVENTS_TTL_DAYS=30
PAYMENT_AUDIT_LOGS_TTL_DAYS=180
PAYMENT_WEBHOOK_DEAD_LETTERS_TTL_DAYS=90
REFUND_WEBHOOK_DEAD_LETTERS_TTL_DAYS=90
JOB_DEAD_LETTERS_TTL_DAYS=180
AUTH_LOGIN_RATE_LIMIT=20
AUTH_LOGIN_RATE_WINDOW_SECONDS=60
AUTH_REGISTER_RATE_LIMIT=10
AUTH_REGISTER_RATE_WINDOW_SECONDS=60
AUTH_REFRESH_RATE_LIMIT=30
AUTH_REFRESH_RATE_WINDOW_SECONDS=60
AUTH_LOGOUT_RATE_LIMIT=30
AUTH_LOGOUT_RATE_WINDOW_SECONDS=60
PAYMENTS_CREATE_RATE_LIMIT=20
PAYMENTS_CREATE_RATE_WINDOW_SECONDS=60
PAYMENTS_WEBHOOK_RATE_LIMIT=120
PAYMENTS_WEBHOOK_RATE_WINDOW_SECONDS=60
REFUNDS_ADMIN_RATE_LIMIT=60
REFUNDS_ADMIN_RATE_WINDOW_SECONDS=60
REFUNDS_WEBHOOK_RATE_LIMIT=120
REFUNDS_WEBHOOK_RATE_WINDOW_SECONDS=60
PAYMENT_WEBHOOK_ALLOWED_IPS=["*"]
REFUND_WEBHOOK_ALLOWED_IPS=["*"]
REFRESH_TOKEN_EXPIRE_DAYS=30
MONEY_BACKFILL_MAX_RETRIES=3
MONEY_BACKFILL_RETRY_DELAY_SECONDS=30

VNPAY_TMN_CODE=demo
VNPAY_HASH_SECRET=replace-with-vnpay-secret
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/payment/return
VNPAY_IPN_URL=http://localhost:8000/api/v1/payments/vnpay/ipn
VNPAY_ENABLED=true
VNPAY_DISPLAY_ORDER=10
VNPAY_MAINTENANCE_MESSAGE=
VNPAY_ICON_URL=
MOMO_PARTNER_CODE=MOMO_DEMO
MOMO_ACCESS_KEY=replace-with-momo-access-key
MOMO_SECRET_KEY=replace-with-momo-secret-key
MOMO_PAYMENT_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/payment/momo-return
MOMO_IPN_URL=http://localhost:8000/api/v1/payments/momo/ipn
MOMO_REQUEST_TYPE=captureWallet
MOMO_ENABLED=true
MOMO_DISPLAY_ORDER=20
MOMO_MAINTENANCE_MESSAGE=
MOMO_ICON_URL=
REFUND_FULL_HOURS=72
REFUND_PARTIAL_HOURS=24
REFUND_PARTIAL_PERCENT=50
REFUND_WEBHOOK_SECRET=replace-with-refund-webhook-secret
REFUND_RECONCILE_TIMEOUT_MINUTES=30
REFUND_RECONCILE_JOB_ENABLED=true
REFUND_RECONCILE_INTERVAL_SECONDS=60
REFUND_RECONCILE_MAX_CONSECUTIVE_FAILURES=5
REFUND_RECONCILE_RETRY_BASE_DELAY_SECONDS=5
REFUND_RECONCILE_RETRY_MAX_DELAY_SECONDS=300

MEDIA_STORAGE_PROVIDER=local
MEDIA_LOCAL_DIR=./media
MEDIA_BASE_URL=/api/v1/media/files
MEDIA_MAX_FILE_SIZE_MB=5
MEDIA_ALLOWED_TYPES=["image/jpeg","image/png","image/webp"]

# Initial admin seed (created once if ADMIN_EMAIL does not exist).
ADMIN_EMAIL=admin@homestay.local
ADMIN_PASSWORD=ChangeMeAdmin@123
ADMIN_FULL_NAME=System Admin
